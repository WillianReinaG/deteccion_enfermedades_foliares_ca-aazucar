# --- IA generativa (OpenAI recomendado) ---
# Copie este archivo como .env y complete su clave. .env NO se sube a GitHub.
OPENAI_API_KEY=sk-su_clave_aqui
OPENAI_MODEL=gpt-4o-mini

# --- Ollama local (opcional, respaldo si no hay OpenAI) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
# En Docker + Ollama en el host Windows use: http://host.docker.internal:11434

# --- Rutas del proyecto ---
MODEL_DIR=models
ARTIFACTS_DIR=artifacts
KNOWLEDGE_DIR=src/app/knowledge_base

# --- Alertas por correo (SendGrid) ---
SENDGRID_API_KEY=
ALERT_EMAIL=bebesowi@gmail.com
ALERT_FROM=noreply@sugarcane.local
ALERT_CONFIDENCE_MIN=0.5

# --- Google Cloud (opcional hasta tener cuenta GCP) ---
GCP_PROJECT_ID=
BQ_DATASET=sugarcane
BQ_TABLE=predictions
GOOGLE_APPLICATION_CREDENTIALS=
